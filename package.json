{
  "name": "hunk",
  "version": "0.1.0",
  "description": "Desktop-inspired terminal diff viewer for agent-authored changesets.",
  "module": "src/main.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "hunk": "./src/main.tsx"
  },
  "scripts": {
    "start": "bun run src/main.tsx",
    "dev": "bun --watch src/main.tsx",
    "build:bin": "bash ./scripts/build-bin.sh",
    "install:bin": "bash ./scripts/install-bin.sh",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:tty-smoke": "bun test test/tty-render-smoke.test.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opentui/core": "^0.1.88",
    "@opentui/react": "^0.1.88",
    "@pierre/diffs": "^1.1.0",
    "commander": "^14.0.3",
    "diff": "^8.0.3",
    "parse-diff": "^0.11.1",
    "react": "^19.2.4"
  },
  "license": "MIT"
}
